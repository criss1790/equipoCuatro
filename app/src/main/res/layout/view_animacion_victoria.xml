<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@drawable/bg_panel_victoria">

    <ImageView
        android:id="@+id/estrellaVictoria1"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:src="@drawable/estrella"
        app:tint="@color/amarillo"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/estrellaVictoria2"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/estrella"
        app:tint="@color/azul"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/estrellaVictoria3"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="12dp"
        android:src="@drawable/estrella"
        app:tint="@color/verde"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/estrellaVictoria4"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="14dp"
        android:src="@drawable/estrella"
        app:tint="@color/naranja"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/estrellaVictoria5"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:src="@drawable/estrella"
        app:tint="@color/amarillo"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/imagenBotellaVictoria"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="18dp"
        android:src="@drawable/rbotella"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/textoEmojiVictoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="108dp"
        android:text="🎉"
        android:textSize="36sp"
        android:alpha="0" />

    <TextView
        android:id="@+id/textoGanasteVictoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="14dp"
        android:text="@string/texto_ganaste"
        android:textColor="@color/naranja"
        android:textSize="26sp"
        android:textStyle="bold"
        android:shadowColor="#CC000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:alpha="0"
        android:scaleX="0"
        android:scaleY="0" />

</FrameLayout>
