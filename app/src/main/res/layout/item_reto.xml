<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gris_oscuro"
        android:orientation="vertical"
        android:paddingBottom="12dp">

        <!-- Fila superior: Íconos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">

            <!-- Ícono superior izquierdo (libre elección: control) -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/desc_icono_reto"
                android:src="@drawable/control"
                app:tint="@color/naranja" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Ícono Editar -->
            <ImageView
                android:id="@+id/iconoEditar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/desc_editar_reto"
                android:focusable="true"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/naranja" />

            <!-- Ícono Eliminar -->
            <ImageView
                android:id="@+id/iconoEliminar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/desc_eliminar_reto"
                android:focusable="true"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/naranja" />
        </LinearLayout>

        <!-- Línea horizontal separadora -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:background="@color/naranja" />

        <!-- Parte inferior: Descripción del reto -->
        <TextView
            android:id="@+id/textoReto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>
</layout>
