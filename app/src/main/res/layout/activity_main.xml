<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/texmadera">

    <!-- Toolbar flotante superior — fondo blanco, borde negro, íconos distribuidos uniformemente -->
    <LinearLayout
        android:id="@+id/toolbarPersonalizada"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/toolbar_flotante"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iconoEstrella"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/estrella"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:tint="@color/naranja"
            android:contentDescription="Favoritos"/>

        <ImageView
            android:id="@+id/iconoSonido"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/sonido"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:tint="@color/naranja"
            android:contentDescription="Sonido"/>

        <ImageView
            android:id="@+id/iconoInstrucciones"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/control"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:tint="@color/naranja"
            android:contentDescription="Instrucciones"/>

        <ImageView
            android:id="@+id/iconoAgregar"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/agregar"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:tint="@color/naranja"
            android:contentDescription="Agregar retos"/>

        <ImageView
            android:id="@+id/iconoCompartir"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/compartir"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            app:tint="@color/naranja"
            android:contentDescription="Compartir"/>

    </LinearLayout>

    <!-- Imagen de botella centrada -->
    <ImageView
        android:id="@+id/imagenBotella"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/rbotella"
        android:contentDescription="Botella"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarPersonalizada"
        app:layout_constraintVertical_bias="0.4" />

    <!-- Contador regresivo superpuesto sobre la botella -->
    <TextView
        android:id="@+id/textoContador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3"
        android:textColor="@color/naranja"
        android:textSize="72sp"
        android:textStyle="bold"
        android:shadowColor="#CC000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/imagenBotella"
        app:layout_constraintEnd_toEndOf="@id/imagenBotella"
        app:layout_constraintStart_toStartOf="@id/imagenBotella"
        app:layout_constraintTop_toTopOf="@id/imagenBotella" />

    <!-- Botón parpadeante inferior -->
    <View
    android:id="@+id/botonPresioname"
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/circle_orange"
    android:clickable="true"
    android:focusable="true"
    android:elevation="6dp"
    app:layout_constraintBottom_toTopOf="@id/textoBotonPresioname"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textoBotonPresioname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:text="Presióname"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="1.5"
        android:shadowDy="1.5"
        android:shadowRadius="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
