<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="40dp">

    <LinearLayout
        android:id="@+id/contenedorCuerpo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_dialogo_reto"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="60dp"
        android:minHeight="200dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtTextoReto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aquí irá el reto del Criterio 3"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <!-- Círculo superior con borde blanco y fondo negro (Perfectamente circular) -->
    <FrameLayout
        android:id="@+id/cardPokemonContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/bg_circle_black_white_border"
        android:elevation="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/contenedorCuerpo"
        app:layout_constraintBottom_toTopOf="@id/contenedorCuerpo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgPokemon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_gallery" />

    </FrameLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCerrar"
        android:layout_width="100dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_naranja_cuadrado"
        android:text="Cerrar"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/contenedorCuerpo"
        app:layout_constraintBottom_toBottomOf="@id/contenedorCuerpo"
        app:layout_constraintStart_toStartOf="@id/contenedorCuerpo"
        app:layout_constraintEnd_toEndOf="@id/contenedorCuerpo" />

</androidx.constraintlayout.widget.ConstraintLayout>
