<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="40dp"> <LinearLayout
    android:id="@+id/contenedorCuerpo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="45dp"
    android:background="@drawable/bg_dialogo_reto"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="60dp"
    android:paddingBottom="45dp" android:gravity="center"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <TextView
        android:id="@+id/txtTextoReto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aquí irá el reto del Criterio 3"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center" />

</LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPokemonContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="45dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#000000"
        app:layout_constraintTop_toTopOf="@id/contenedorCuerpo"
        app:layout_constraintBottom_toTopOf="@id/contenedorCuerpo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:padding="3dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgPokemon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_gallery" />

            </FrameLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCerrar"
        android:layout_width="100dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_naranja_cuadrado"
        android:text="Cerrar"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/contenedorCuerpo"
        app:layout_constraintBottom_toBottomOf="@id/contenedorCuerpo"
        app:layout_constraintStart_toStartOf="@id/contenedorCuerpo"
        app:layout_constraintEnd_toEndOf="@id/contenedorCuerpo" />

</androidx.constraintlayout.widget.ConstraintLayout>