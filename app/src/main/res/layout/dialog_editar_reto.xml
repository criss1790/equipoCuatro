<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialogo_blanco"
        android:padding="24dp">

        <!-- C2 — título "Editar reto", centrado, negro, bold -->
        <TextView
            android:id="@+id/tituloDialogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_editar_reto"
            android:gravity="center"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="18sp" />

        <!-- C3 — caja precargada desde la BD, con línea naranja (sin hint) -->
        <EditText
            android:id="@+id/campoReto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/black"
            android:backgroundTint="@color/naranja"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- C4 — Cancelar naranja -->
            <Button
                android:id="@+id/botonCancelar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/boton_cancelar"
                android:background="@drawable/btn_naranja_redondeado"
                android:textColor="@color/white" />

            <!-- C5 — Guardar naranja, SIEMPRE habilitado (sin TextWatcher) -->
            <Button
                android:id="@+id/botonGuardar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/boton_guardar"
                android:background="@drawable/btn_naranja_redondeado"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</layout>
